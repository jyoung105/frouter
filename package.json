{
  "name": "free-router",
  "version": "1.2.0",
  "description": "Free model router — discover, ping, and configure free AI models for OpenCode / OpenClaw",
  "bin": {
    "free-router": "dist/bin/free-router.js"
  },
  "type": "module",
  "packageManager": "bun@1.3.5",
  "scripts": {
    "build": "tsc -p tsconfig.json && cp data/model-rankings.json data/model-support.json dist/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "pretest": "npm run build",
    "test": "node --test dist/tests/unit/*.test.js dist/tests/integration/*.test.js dist/tests/security/*.test.js",
    "test:perf": "npm run build && node --expose-gc --test dist/tests/perf/*.perf.test.js",
    "perf:baseline": "npm run build && node dist/tests/perf/collect-baseline.js",
    "models:sync": "npx tsx scripts/update-models.ts",
    "models:sync:apply": "npx tsx scripts/update-models.ts --apply",
    "test:onboarding": "node --test dist/tests/integration/onboarding.test.js",
    "test:fresh-start": "npm run build && bash ./scripts/free-router-fresh-start.sh",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist/bin/",
    "dist/lib/",
    "dist/tui/",
    "dist/model-rankings.json",
    "dist/model-support.json",
    "scripts/free-router-fresh-start.sh"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jyoung105/free-router.git"
  },
  "homepage": "https://github.com/jyoung105/free-router#readme",
  "author": "Tony Lee",
  "keywords": [
    "ai",
    "cli",
    "tui",
    "free-models",
    "openrouter",
    "nvidia",
    "nim",
    "opencode",
    "openclaw",
    "llm",
    "free-api"
  ],
  "license": "MIT",
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "ink": "^7.0.1",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
