{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/models/:slug/index.html",
      "destination": "/models/:slug/",
      "permanent": true
    },
    {
      "source": "/models/:slug",
      "destination": "/models/:slug/",
      "permanent": true
    }
  ]
}
